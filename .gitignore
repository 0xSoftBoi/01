# Foundry (audit/)
audit/out/
audit/cache/
audit/lib/

# Daml / web / iOS build outputs (canton/kyd-tix)
**/.daml/
**/dist/
**/daml.js/
# Vercel's git-integration build for app/ and CI's server job both have no
# Daml SDK to run `daml codegen js`, so app/daml.js and server/daml.js are
# committed as build artifacts — regenerate (`npm run codegen` in app/ and
# server/) and recommit whenever the Daml model changes.
!canton/kyd-tix/app/daml.js/
!canton/kyd-tix/server/daml.js/
**/node_modules/
*.dar
canton/kyd-tix/log/
canton/kyd-tix/server/auth-proof/log/
canton/kyd-tix/app/public/demo-parties.json
canton/kyd-tix/ios/**/*.xcodeproj

# Misc build artifacts / OS files
artifacts/
.DS_Store
