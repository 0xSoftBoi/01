{
  "name": "kyd-tix-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Custody boundary in front of the ledger: real RS256/JWKS auth issuance, a server-side operator session for catalog reads and PSP-triggered minting — nothing operator-scoped ever reaches the browser.",
  "scripts": {
    "codegen": "daml codegen js ../.daml/dist/kyd-tix-0.1.0.dar -o daml.js -s kyd",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@daml/ledger": "2.10.4",
    "@daml/types": "2.10.4",
    "@kyd/kyd-tix-0.1.0": "file:daml.js/kyd-tix-0.1.0",
    "express": "^4.21.1",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
