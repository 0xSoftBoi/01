-- | Daml Script tests. Run with `daml test` (no ledger required) or load into
--   `daml start` / Navigator. Each `Script ()` below is an independent scenario.
module Kyd.Test where

import Daml.Script
import DA.Assert ((===))
import DA.Date (date, Month(..))
import DA.Time (time)

import Kyd.Cash
import Kyd.Roles
import Kyd.Event
import Kyd.Settlement
import Kyd.Ticket
import Kyd.Tix

-- A reusable cast of parties.
data Cast = Cast
  with
    operator : Party
    venue : Party
    artist : Party
    alice : Party   -- first fan / seller
    bob : Party     -- second fan / buyer
    lender : Party
    lender2 : Party
    public : Party  -- broadcast party for the open order book

setupCast : Script Cast
setupCast = do
  operator <- allocateParty "KYD-Operator"
  venue    <- allocateParty "Venue"
  artist   <- allocateParty "Artist"
  alice    <- allocateParty "Alice"
  bob      <- allocateParty "Bob"
  lender   <- allocateParty "Lender"
  lender2  <- allocateParty "Lender2"
  public   <- allocateParty "Public"
  pure Cast with ..

-- Onboard a party into a role (operator invites, party accepts).
onboard : Cast -> Party -> RoleType -> Script ()
onboard c member role = do
  inv <- submit c.operator $ createCmd Invitation with
    operator = c.operator, invitee = member, role
  _ <- submit member $ exerciseCmd inv Invitation_Accept
  pure ()

-- Mint operator cash to a party.
mint : Cast -> Party -> Decimal -> Script (ContractId Cash)
mint c owner amount = submit c.operator $ createCmd Cash with
  operator = c.operator, owner, amount
  lock = None, lockRecipient = None, lockCoSigner = None, observers = []

-- Sum a party's spendable cash: notes it owns that are NOT locked (locked
-- holdings are reserved in place by the registry for an in-flight allocation)
-- and not merely disclosed to it.
cashOf : Party -> Script Decimal
cashOf p = do
  notes <- query @Cash p
  pure (foldl (\acc (_, c) -> if c.owner == p && c.lock == None then acc + c.amount else acc) 0.0 notes)

-- A single-tier event master: GA at 50 with no demand escalator, a 1.5x
-- resale cap (so 75 on a face-price purchase), a 10% artist royalty and a 50%
-- financing carve-out on paid sales.
makeEvent : Cast -> Script (ContractId Event)
makeEvent c =
  submitMulti [c.operator, c.venue, c.artist] [] $ createCmd Event with
    operator = c.operator
    venue = c.venue
    artist = c.artist
    eventId = "SHOW-001"
    name = "Robert Plant — Live"
    eventTime = time (date 2026 Jul 4) 20 0 0
    royaltyBps = 1000
    financingShareBps = 5000
    tiers = [Tier with tierId = "GA", basePrice = 50.0, demandBps = 0, resaleCapBps = 15000, supply = 100, allocated = 0]

-- Carve a GA shard of `size` off the master; returns (new master, hot shard).
openGA : Cast -> ContractId Event -> Int -> Script (ContractId Event, ContractId TierAllocation)
openGA c ev size =
  submit c.venue $ exerciseCmd ev (Event_OpenAllocation with tierId = "GA", size)

-- 1. Onboarding handshake produces a counter-signed membership.
testOnboarding : Script ()
testOnboarding = do
  c <- setupCast
  inv <- submit c.operator $ createCmd Invitation with
    operator = c.operator, invitee = c.venue, role = Venue
  _ <- submit c.venue $ exerciseCmd inv Invitation_Accept
  memberships <- query @Membership c.venue
  length memberships === 1

-- 2. Primary sale: a shard is carved off the master, mints to the fan, and
--    the shard's counter advances while the master stays untouched.
testPrimarySale : Script ()
testPrimarySale = do
  c <- setupCast
  ev <- makeEvent c
  (_ev1, alloc) <- openGA c ev 5
  (Some alloc1, _t1) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd alloc (Allocation_Issue with fan = c.alice)
  Some alloc1Data <- queryContractId c.operator alloc1
  alloc1Data.sold === 1
  aliceTickets <- query @Ticket c.alice
  length aliceTickets === 1

-- 3. Resale within the cap: royalty to the artist, remainder to the seller,
--    ownership to the buyer — all atomic.
testResaleWithRoyalty : Script ()
testResaleWithRoyalty = do
  c <- setupCast
  ev <- makeEvent c
  (_ev1, alloc) <- openGA c ev 1
  (None, t1) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd alloc (Allocation_Issue with fan = c.alice)

  -- Buyer is funded with exactly the 70 sale price.
  cash <- mint c c.bob 70.0

  offer <- submit c.alice $ exerciseCmd t1 (Ticket_Offer with buyer = c.bob, salePrice = 70.0)
  t2 <- submit c.bob $ exerciseCmd offer (ResaleOffer_Accept with cashCid = cash)

  -- 10% of 70 = 7 to the artist, 63 to the seller, ticket now owned by Bob.
  artistBal <- cashOf c.artist
  aliceBal  <- cashOf c.alice
  bobBal    <- cashOf c.bob
  artistBal === 7.0
  aliceBal  === 63.0
  bobBal    === 0.0

  Some t2Data <- queryContractId c.operator t2
  t2Data.owner === c.bob

-- 4. The anti-scalping cap is enforced: an over-cap offer is rejected.
testResaleCapEnforced : Script ()
testResaleCapEnforced = do
  c <- setupCast
  ev <- makeEvent c
  (_ev1, alloc) <- openGA c ev 1
  (None, t1) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd alloc (Allocation_Issue with fan = c.alice)
  -- Cap is 75; offering at 100 must fail.
  submitMustFail c.alice $ exerciseCmd t1 (Ticket_Offer with buyer = c.bob, salePrice = 100.0)

-- 5. A redeemed (checked-in) ticket can no longer be resold.
testRedeemedCannotResell : Script ()
testRedeemedCannotResell = do
  c <- setupCast
  ev <- makeEvent c
  (_ev1, alloc) <- openGA c ev 1
  (None, t1) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd alloc (Allocation_Issue with fan = c.alice)
  setTime (time (date 2026 Jul 4) 20 0 0)   -- showtime: within the doors window
  t1r <- submit c.venue $ exerciseCmd t1 Ticket_CheckIn
  submitMustFail c.alice $ exerciseCmd t1r (Ticket_Offer with buyer = c.bob, salePrice = 50.0)

-- An offering raising 1,000 at a 1.10x factor rate, 50% revenue share,
-- maturity 1 Aug 2026 and 10bps/day late interest, open to both lenders.
makeOffering : Cast -> Script (ContractId FinancingOffering)
makeOffering c =
  submitMulti [c.operator, c.venue] [] $ createCmd FinancingOffering with
    operator = c.operator
    venue = c.venue
    eventId = "SHOW-001"
    target = 1000.0
    factorRateBps = 11000
    revenueShareBps = 5000
    dueDate = time (date 2026 Aug 1) 0 0 0
    lateInterestBpsPerDay = 10
    invited = [c.lender, c.lender2]
    commitments = []

-- A fully subscribed and activated syndication: lender commits 600 and
-- lender2 400, leaving the venue with the 1,000 principal (two notes) and a
-- loan register of [lender2 owed 440, lender owed 660].
setupLoan : Cast -> Script (ContractId SyndicatedLoan, [ContractId Cash])
setupLoan c = do
  _ <- makeEvent c
  off <- makeOffering c
  n600 <- mint c c.lender 600.0
  off2 <- submit c.lender $ exerciseCmd off (Offering_Commit with lender = c.lender, cashCid = n600)
  n400 <- mint c c.lender2 400.0
  off3 <- submit c.lender2 $ exerciseCmd off2 (Offering_Commit with lender = c.lender2, cashCid = n400)
  submit c.venue $ exerciseCmd off3 Offering_Activate

-- 6. TIX end-to-end: two lenders syndicate a 1,000 raise at 1.10x; repayment
--    flows through revenue-share settlement, a direct pro-rata distribution,
--    late-interest accrual past maturity, and a final payoff.
testSyndicatedFinancing : Script ()
testSyndicatedFinancing = do
  c <- setupCast
  _ <- makeEvent c
  off <- makeOffering c

  -- Lender 1 commits 600 (escrowed with the operator).
  n600 <- mint c c.lender 600.0
  off2 <- submit c.lender $ exerciseCmd off (Offering_Commit with lender = c.lender, cashCid = n600)

  -- Guards: uninvited party cannot commit; a lender cannot commit twice;
  -- the venue cannot activate an undersubscribed offering.
  nAlice <- mint c c.alice 100.0
  submitMustFail c.alice $ exerciseCmd off2 (Offering_Commit with lender = c.alice, cashCid = nAlice)
  n50 <- mint c c.lender 50.0
  submitMustFail c.lender $ exerciseCmd off2 (Offering_Commit with lender = c.lender, cashCid = n50)
  submitMustFail c.venue $ exerciseCmd off2 Offering_Activate

  -- Lender 2 cannot over-commit past the target; splits its note to fit.
  n500 <- mint c c.lender2 500.0
  submitMustFail c.lender2 $ exerciseCmd off2 (Offering_Commit with lender = c.lender2, cashCid = n500)
  (n400, _n100) <- submit c.lender2 $ exerciseCmd n500 (Cash_Split with splitAmount = 100.0)
  off3 <- submit c.lender2 $ exerciseCmd off2 (Offering_Commit with lender = c.lender2, cashCid = n400)

  -- Fully subscribed: activation pays the venue 1,000 and books the loan with
  -- entitlements of 1.10x each: lender2 owed 440, lender owed 660.
  (loan, [p400, p600]) <- submit c.venue $ exerciseCmd off3 Offering_Activate
  venueBal0 <- cashOf c.venue
  venueBal0 === 1000.0
  Some loanData <- queryContractId c.operator loan
  loanData.tranches === [Tranche c.lender2 440.0, Tranche c.lender 660.0]

  -- Late interest cannot accrue before maturity.
  submitMustFail c.operator $ exerciseCmd loan Loan_AccrueLateInterest

  -- A 200 ticket sale settles through the loan: 50% (100) is carved out for
  -- the syndicate pro-rata (lender 60, lender2 40); the venue keeps 100.
  rev <- mint c c.venue 200.0
  (Some loan2, Some kept100) <- submit c.venue $ exerciseCmd loan (Loan_SettleRevenue with revenueCid = rev)

  -- Direct paydown of 500, split pro-rata (lender 300, lender2 200).
  n500v <- submit c.venue $ exerciseCmd p400 (Cash_Merge with otherCid = kept100)
  Some loan3 <- submit c.venue $ exerciseCmd loan2 (Loan_Distribute with cashCid = n500v)
  Some loan3Data <- queryContractId c.operator loan3
  loan3Data.tranches === [Tranche c.lender2 200.0, Tranche c.lender 300.0]

  -- Ten full days past the 1 Aug maturity at 10bps/day: outstanding grows 1%.
  setTime (time (date 2026 Aug 11) 0 0 0)
  loan4 <- submit c.operator $ exerciseCmd loan3 Loan_AccrueLateInterest
  Some loan4Data <- queryContractId c.operator loan4
  loan4Data.tranches === [Tranche c.lender2 202.0, Tranche c.lender 303.0]
  -- Accruing twice on the same day is rejected.
  submitMustFail c.operator $ exerciseCmd loan4 Loan_AccrueLateInterest

  -- Final payoff of 505 retires the loan.
  (kept95, pay505) <- submit c.venue $ exerciseCmd p600 (Cash_Split with splitAmount = 505.0)
  None <- submit c.venue $ exerciseCmd loan4 (Loan_Distribute with cashCid = pay505)

  -- Lender 1: 60 + 300 + 303 = 663; lender 2: 40 + 200 + 202 = 442 (a 10%
  -- yield plus late interest); venue keeps 95 of the cash it handled.
  lenderBal  <- cashOf c.lender
  lender2Bal <- cashOf c.lender2
  venueBal   <- cashOf c.venue
  lenderBal  === 713.0  -- 663 via the waterfall + the unused 50 note
  lender2Bal === 542.0  -- 442 via the waterfall + the unused 100 split
  venueBal   === 95.0
  openLoans <- query @SyndicatedLoan c.venue
  length openLoans === 0

-- 7. A lender can withdraw a commitment, and cancelling an offering refunds
--    every escrowed commitment in full.
testOfferingCancelAndUncommit : Script ()
testOfferingCancelAndUncommit = do
  c <- setupCast
  off <- makeOffering c

  n600 <- mint c c.lender 600.0
  off2 <- submit c.lender $ exerciseCmd off (Offering_Commit with lender = c.lender, cashCid = n600)
  escrowedBal <- cashOf c.lender
  escrowedBal === 0.0

  -- Withdraw: the escrow comes straight back.
  off3 <- submit c.lender $ exerciseCmd off2 (Offering_Uncommit with lender = c.lender)
  refundedBal <- cashOf c.lender
  refundedBal === 600.0

  -- Re-commit, then the venue cancels the raise: refunded again.
  [(n600b, _)] <- query @Cash c.lender
  off4 <- submit c.lender $ exerciseCmd off3 (Offering_Commit with lender = c.lender, cashCid = n600b)
  submit c.venue $ exerciseCmd off4 Offering_Cancel
  finalBal <- cashOf c.lender
  finalBal === 600.0
  offerings <- query @FinancingOffering c.venue
  length offerings === 0

-- 8. Paid primary sale, contention-decoupled: the fill atomically pays the
--    venue, carves the lenders' 50% share into an escrowed receipt (the loan
--    is NOT touched on the hot path), and mints the ticket. The sweep then
--    batches receipts through the loan.
testPaidPrimarySaleRoutesRevenue : Script ()
testPaidPrimarySaleRoutesRevenue = do
  c <- setupCast
  (loan, _) <- setupLoan c
  [(ev, _)] <- query @Event c.venue
  (_ev1, alloc) <- openGA c ev 5

  -- An order that underpays the 50 shard price cannot be filled.
  n40 <- mint c c.alice 40.0
  badOrder <- submit c.alice $ createCmd PurchaseOrder with
    operator = c.operator, venue = c.venue, fan = c.alice, eventId = "SHOW-001", tierId = "GA", cashCid = n40
  submitMustFail c.operator $ exerciseCmd badOrder (PurchaseOrder_Fill with allocationCid = alloc)

  -- Exact price fills: venue keeps 25 immediately; 25 sits in an escrowed
  -- receipt; the lenders have received nothing yet and the loan is untouched.
  n50 <- mint c c.alice 50.0
  order <- submit c.alice $ createCmd PurchaseOrder with
    operator = c.operator, venue = c.venue, fan = c.alice, eventId = "SHOW-001", tierId = "GA", cashCid = n50
  (_, ticketCid) <- submit c.operator $ exerciseCmd order (PurchaseOrder_Fill with allocationCid = alloc)

  Some t <- queryContractId c.alice ticketCid
  t.owner === c.alice
  [(receiptCid, receipt)] <- query @RevenueShare c.operator
  receipt.amount === 25.0
  lendersBefore <- cashOf c.lender
  lendersBefore === 0.0
  venueBal <- cashOf c.venue
  venueBal === 1025.0   -- 1,000 principal + the 25 retained from the sale

  -- The sweep settles the receipt pro-rata over the register (440/660):
  -- lender2 gets 10, lender gets 15.
  (Some _, None) <- submit c.operator $ exerciseCmd loan (Loan_SweepRevenue with receiptCids = [receiptCid])
  lender2Bal <- cashOf c.lender2
  lenderBal  <- cashOf c.lender
  lender2Bal === 10.0
  lenderBal  === 15.0
  [(_, loanData)] <- query @SyndicatedLoan c.venue
  loanData.tranches === [Tranche c.lender2 430.0, Tranche c.lender 645.0]

-- 9. Secondary market: a lender sells part of its tranche to an onboarded
--    buyer at a discount; payment and register update are one atomic DvP, and
--    the buyer participates pro-rata in subsequent distributions.
testTrancheSecondaryTrading : Script ()
testTrancheSecondaryTrading = do
  c <- setupCast
  (loan, [p400, p600]) <- setupLoan c

  -- Bob onboards as a lender (the KYC gate for the secondary market).
  inv <- submit c.operator $ createCmd Invitation with
    operator = c.operator, invitee = c.bob, role = Lender
  _ <- submit c.bob $ exerciseCmd inv Invitation_Accept

  -- A lender cannot list more than its outstanding claim.
  submitMustFail c.lender $ exerciseCmd loan
    (Loan_OfferTranche with seller = c.lender, buyer = c.bob, faceAmount = 700.0, price = 600.0)

  -- A non-onboarded buyer is rejected at the KYC gate.
  offerA <- submit c.lender $ exerciseCmd loan
    (Loan_OfferTranche with seller = c.lender, buyer = c.alice, faceAmount = 100.0, price = 90.0)
  nAlice <- mint c c.alice 90.0
  submitMultiMustFail [c.alice, c.operator] [] $ exerciseCmd offerA (TrancheOffer_Accept with cashCid = nAlice)

  -- Lender sells 300 of face to Bob for 270 (a 10% discount).
  offer <- submit c.lender $ exerciseCmd loan
    (Loan_OfferTranche with seller = c.lender, buyer = c.bob, faceAmount = 300.0, price = 270.0)
  n270 <- mint c c.bob 270.0
  loan2 <- submitMulti [c.bob, c.operator] [] $ exerciseCmd offer (TrancheOffer_Accept with cashCid = n270)

  Some loan2Data <- queryContractId c.operator loan2
  loan2Data.tranches === [Tranche c.lender2 440.0, Tranche c.lender 360.0, Tranche c.bob 300.0]
  sellerBal <- cashOf c.lender
  sellerBal === 270.0

  -- A 550 distribution over the new register (440/360/300 of 1,100):
  -- lender2 220, lender 180, Bob 150.
  n1000 <- submit c.venue $ exerciseCmd p600 (Cash_Merge with otherCid = p400)
  (_kept, pay550) <- submit c.venue $ exerciseCmd n1000 (Cash_Split with splitAmount = 550.0)
  Some _loan3 <- submit c.venue $ exerciseCmd loan2 (Loan_Distribute with cashCid = pay550)

  lender2Bal <- cashOf c.lender2
  sellerBal2 <- cashOf c.lender
  bobBal     <- cashOf c.bob
  lender2Bal === 220.0
  sellerBal2 === 450.0   -- 270 sale proceeds + 180 from the distribution
  bobBal     === 150.0

-- A fan buys one ticket from a specific shard through the operator's engine;
-- returns the shard's successor cid (None when exhausted) and the ticket.
buyFrom : Cast -> Party -> Text -> Text -> ContractId TierAllocation -> Decimal -> Script (Optional (ContractId TierAllocation), ContractId Ticket)
buyFrom c fan eventId tierId allocCid price = do
  n <- mint c fan price
  order <- submit fan $ createCmd PurchaseOrder with
    operator = c.operator, venue = c.venue, fan, eventId, tierId, cashCid = n
  submit c.operator $ exerciseCmd order (PurchaseOrder_Fill with allocationCid = allocCid)

-- As 'buyFrom', discarding the successor (for single sales / size-1 shards).
buy : Cast -> Party -> Text -> Text -> ContractId TierAllocation -> Decimal -> Script (ContractId Ticket)
buy c fan eventId tierId allocCid price = do
  (_, ticketCid) <- buyFrom c fan eventId tierId allocCid price
  pure ticketCid

-- A purchase attempt that must be rejected at fill time.
buyMustFail : Cast -> Party -> Text -> Text -> ContractId TierAllocation -> Decimal -> Script ()
buyMustFail c fan eventId tierId allocCid price = do
  n <- mint c fan price
  order <- submit fan $ createCmd PurchaseOrder with
    operator = c.operator, venue = c.venue, fan, eventId, tierId, cashCid = n
  submitMustFail c.operator $ exerciseCmd order (PurchaseOrder_Fill with allocationCid = allocCid)

-- 10. Tiered seating + dynamic pricing as a step curve over allocations:
--     each successive GA shard prices 2% of base higher while VIP stays flat;
--     resale caps anchor to the price each fan actually paid; supply is
--     enforced at the master; venue/artist reprice shards, nobody else.
testTieredDynamicPricing : Script ()
testTieredDynamicPricing = do
  c <- setupCast
  ev0 <- submitMulti [c.operator, c.venue, c.artist] [] $ createCmd Event with
    operator = c.operator
    venue = c.venue
    artist = c.artist
    eventId = "SHOW-002"
    name = "Charli XCX — Live"
    eventTime = time (date 2026 Sep 1) 21 0 0
    royaltyBps = 1000
    financingShareBps = 0
    tiers =
      [ Tier with tierId = "GA",  basePrice = 50.0,  demandBps = 200, resaleCapBps = 15000, supply = 3, allocated = 0
      , Tier with tierId = "VIP", basePrice = 100.0, demandBps = 0,   resaleCapBps = 12000, supply = 2, allocated = 0
      ]
  let openTier evCid tierId size = submit c.venue $ exerciseCmd evCid (Event_OpenAllocation with tierId, size)

  -- GA demand steps: shards open at 50, 51, 52; paying a stale price fails.
  (ev1, ga1) <- openTier ev0 "GA" 1
  _t1 <- buy c c.alice "SHOW-002" "GA" ga1 50.0
  (ev2, ga2) <- openTier ev1 "GA" 1
  buyMustFail c c.bob "SHOW-002" "GA" ga2 50.0
  t2 <- buy c c.bob "SHOW-002" "GA" ga2 51.0
  (ev3, ga3) <- openTier ev2 "GA" 1
  _t3 <- buy c c.alice "SHOW-002" "GA" ga3 52.0
  -- GA supply (3) is exhausted at the master: no further shard can open.
  submitMustFail c.venue $ exerciseCmd ev3 (Event_OpenAllocation with tierId = "GA", size = 1)

  -- The resale cap anchors to the price Bob actually paid: 51 x 1.5 = 76.5.
  Some t2Data <- queryContractId c.bob t2
  t2Data.facePrice === 51.0
  t2Data.maxResalePrice === 76.5
  submitMustFail c.bob $ exerciseCmd t2 (Ticket_Offer with buyer = c.alice, salePrice = 77.0)
  resale <- submit c.bob $ exerciseCmd t2 (Ticket_Offer with buyer = c.alice, salePrice = 76.5)
  _ <- submit c.bob $ exerciseCmd resale ResaleOffer_Withdraw

  -- VIP is untouched by GA demand: still 100. The artist reprices the second
  -- shard to 80; a random party cannot reprice.
  (ev4, vip1) <- openTier ev3 "VIP" 1
  _t4 <- buy c c.bob "SHOW-002" "VIP" vip1 100.0
  (_ev5, vip2) <- openTier ev4 "VIP" 1
  submitMustFail c.bob $ exerciseCmd vip2 (Allocation_Reprice with repricer = c.bob, newPrice = 1.0)
  vip2' <- submitMulti [c.operator, c.artist] [] $ exerciseCmd vip2 (Allocation_Reprice with repricer = c.artist, newPrice = 80.0)
  _t5 <- buy c c.alice "SHOW-002" "VIP" vip2' 80.0

  -- Venue collected every primary sale: 50 + 51 + 52 + 100 + 80 = 333.
  venueBal <- cashOf c.venue
  venueBal === 333.0

-- 12. Contention engineering: two shards of the same tier serve sales fully
--     independently — issuing from one never touches the other or the master —
--     and their serial ranges are disjoint by construction.
testParallelShards : Script ()
testParallelShards = do
  c <- setupCast
  ev <- makeEvent c
  (ev1, shardA) <- openGA c ev 2    -- serials 1-2
  (_ev2, shardB) <- openGA c ev1 2  -- serials 3-4

  -- Sell from B first, then A: neither exercise references the other shard or
  -- the master, so on Canton these submissions commute (no write-write
  -- contention).
  (Some _, tB) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd shardB (Allocation_Issue with fan = c.bob)
  (Some _, tA) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd shardA (Allocation_Issue with fan = c.alice)
  Some tBData <- queryContractId c.operator tB
  Some tAData <- queryContractId c.operator tA
  tBData.serial === 3
  tAData.serial === 1

-- 13. Batch sweep: five sales produce five create-only receipts; ONE consuming
--     exercise on the loan settles them all. Receipts beyond the remaining
--     debt retire the loan and the excess returns to the venue.
testBatchSweep : Script ()
testBatchSweep = do
  c <- setupCast
  (loan, [p400, p600]) <- setupLoan c
  [(ev, _)] <- query @Event c.venue
  (_ev1, alloc) <- openGA c ev 5

  -- Five sales at 50, threading the shard's successor cid: each sale carves
  -- 25 into a create-only receipt (125 escrowed in total).
  (Some a2, _) <- buyFrom c c.alice "SHOW-001" "GA" alloc 50.0
  (Some a3, _) <- buyFrom c c.bob   "SHOW-001" "GA" a2 50.0
  (Some a4, _) <- buyFrom c c.alice "SHOW-001" "GA" a3 50.0
  (Some a5, _) <- buyFrom c c.bob   "SHOW-001" "GA" a4 50.0
  (None, _)   <- buyFrom c c.alice "SHOW-001" "GA" a5 50.0
  receipts <- query @RevenueShare c.operator
  length receipts === 5

  -- Venue pays down 1,000 of the 1,100 register first: tranches drop to 40/60.
  n1000 <- submit c.venue $ exerciseCmd p600 (Cash_Merge with otherCid = p400)
  Some loan2 <- submit c.venue $ exerciseCmd loan (Loan_Distribute with cashCid = n1000)

  -- One sweep of all five receipts: 100 clears the register (lender2 +40,
  -- lender +60), the loan is retired, and the 25 excess returns to the venue.
  (None, Some _) <- submit c.operator $ exerciseCmd loan2
    (Loan_SweepRevenue with receiptCids = map fst receipts)
  lender2Bal <- cashOf c.lender2
  lenderBal  <- cashOf c.lender
  venueBal   <- cashOf c.venue
  lender2Bal === 440.0   -- exactly its 1.10x entitlement
  lenderBal  === 660.0   -- exactly its 1.10x entitlement
  venueBal   === 150.0   -- 1,000 principal + 125 kept halves - 1,000 repaid + 25 excess
  remainingLoans <- query @SyndicatedLoan c.venue
  length remainingLoans === 0
  remainingReceipts <- query @RevenueShare c.operator
  length remainingReceipts === 0

-- 14. Receipt refund: with no facility owed, operator and venue jointly
--     return an escrowed share to the venue.
testReceiptRefund : Script ()
testReceiptRefund = do
  c <- setupCast
  ev <- makeEvent c   -- 50% carve-out configured, but no loan is ever raised
  (_ev1, alloc) <- openGA c ev 1
  _ <- buy c c.alice "SHOW-001" "GA" alloc 50.0
  [(receiptCid, receipt)] <- query @RevenueShare c.operator
  receipt.amount === 25.0
  _ <- submitMulti [c.operator, c.venue] [] $ exerciseCmd receiptCid Receipt_Refund
  venueBal <- cashOf c.venue
  venueBal === 50.0   -- the 25 kept at sale + the 25 refunded share
  remainingReceipts <- query @RevenueShare c.operator
  length remainingReceipts === 0

-- 11. Open order book: a non-invited raise broadcast to the public party. Any
--     onboarded lender discovers it and commits; non-onboarded parties are
--     rejected at the KYC gate; once fully subscribed it converts to the same
--     syndicated loan as the invited path.
testOpenOrderBook : Script ()
testOpenOrderBook = do
  c <- setupCast

  -- Two lenders hold KYC credentials; Alice does not.
  onboard c c.lender Lender
  onboard c c.lender2 Lender

  -- Venue opens a 1,000 raise to the public book (no invite list).
  off <- submitMulti [c.operator, c.venue] [] $ createCmd OpenOfferingListing with
    operator = c.operator
    venue = c.venue
    public = c.public
    eventId = "SHOW-OPEN"
    target = 1000.0
    factorRateBps = 11000
    revenueShareBps = 5000
    dueDate = time (date 2026 Aug 1) 0 0 0
    lateInterestBpsPerDay = 10
    raised = 0.0

  -- A non-onboarded party reading the public book still cannot commit.
  nAlice <- mint c c.alice 100.0
  submitMultiMustFail [c.alice] [c.public] $
    exerciseCmd off (Listing_Commit with lender = c.alice, cashCid = nAlice)

  -- Onboarded lenders discover the book via readAs public and commit 600 / 400.
  -- Each commitment is a PRIVATE OpenCommitment; the listing only sees totals.
  n600 <- mint c c.lender 600.0
  (off2, com1) <- submitMulti [c.lender] [c.public] $
    exerciseCmd off (Listing_Commit with lender = c.lender, cashCid = n600)
  n400 <- mint c c.lender2 400.0
  (off3, com2) <- submitMulti [c.lender2] [c.public] $
    exerciseCmd off2 (Listing_Commit with lender = c.lender2, cashCid = n400)

  -- KYD-09: the public party sees the aggregate raised but NOT who committed —
  -- it cannot see any OpenCommitment (lender identities / amounts are private).
  Some off3Data <- queryContractId c.operator off3
  off3Data.raised === 1000.0
  publicCommitments <- query @OpenCommitment c.public
  length publicCommitments === 0
  -- Each lender sees only its own commitment.
  lenderCommitments <- query @OpenCommitment c.lender
  length lenderCommitments === 1

  -- Fully subscribed: activation pays the venue 1,000 and books the loan.
  (loan, _proceeds) <- submit c.venue $
    exerciseCmd off3 (Listing_Activate with commitmentCids = [com1, com2])
  venueBal <- cashOf c.venue
  venueBal === 1000.0
  Some loanData <- queryContractId c.operator loan
  loanData.tranches === [Tranche c.lender 660.0, Tranche c.lender2 440.0]

-- 15. Gifting: free transfer with the recipient's consent; the ticket is
--     locked while the offer is open; decline hands it back.
testGiftFlow : Script ()
testGiftFlow = do
  c <- setupCast
  ev <- makeEvent c
  (_ev1, alloc) <- openGA c ev 1
  (None, t1) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd alloc (Allocation_Issue with fan = c.alice)
  gift <- submit c.alice $ exerciseCmd t1 (Ticket_OfferGift with recipient = c.bob)
  -- Locked: the archived ticket cannot also be listed for sale.
  submitMustFail c.alice $ exerciseCmd t1 (Ticket_Offer with buyer = c.bob, salePrice = 50.0)
  t2 <- submit c.bob $ exerciseCmd gift GiftOffer_Accept
  Some t2Data <- queryContractId c.operator t2
  t2Data.owner === c.bob
  -- Bob regifts back; Alice declines; Bob keeps it.
  gift2 <- submit c.bob $ exerciseCmd t2 (Ticket_OfferGift with recipient = c.alice)
  t3 <- submit c.alice $ exerciseCmd gift2 GiftOffer_Decline
  Some t3Data <- queryContractId c.operator t3
  t3Data.owner === c.bob

-- 16. Refunds: the venue makes the fan whole at exactly the price paid and
--     the ticket is withdrawn atomically.
testRefund : Script ()
testRefund = do
  c <- setupCast
  ev <- makeEvent c
  (_ev1, alloc) <- openGA c ev 1
  (None, t1) <- submitMulti [c.operator, c.venue] [] $ exerciseCmd alloc (Allocation_Issue with fan = c.alice)
  n50 <- mint c c.venue 50.0
  _ <- submit c.venue $ exerciseCmd t1 (Ticket_Refund with cashCid = n50)
  aliceBal <- cashOf c.alice
  aliceBal === 50.0
  tickets <- query @Ticket c.alice
  length tickets === 0

-- 17. Lock expiry safety valve: a lender can always reclaim its committed funds
--     once the offering's due date passes, even if the venue never activates or
--     cancels — lock-in-place can't freeze funds indefinitely.
testCommitmentExpiryReclaim : Script ()
testCommitmentExpiryReclaim = do
  c <- setupCast
  _ <- makeEvent c
  off <- makeOffering c   -- dueDate 1 Aug 2026
  n <- mint c c.lender 600.0
  _ <- submit c.lender $ exerciseCmd off (Offering_Commit with lender = c.lender, cashCid = n)
  [(lockedCid, _)] <- query @Cash c.lender
  -- Before the due date the lender cannot reclaim.
  submitMustFail c.lender $ exerciseCmd lockedCid Cash_UnlockExpired
  -- After the due date the lender reclaims unilaterally.
  setTime (time (date 2026 Aug 2) 0 0 0)
  _ <- submit c.lender $ exerciseCmd lockedCid Cash_UnlockExpired
  bal <- cashOf c.lender
  bal === 600.0
